<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.later-brain.helper</string>
  <key>ProgramArguments</key>
  <array>
    <string>__NODE__</string>
    <string>__DIR__/helper/src/index.js</string>
  </array>
  <key>WorkingDirectory</key><string>__DIR__/helper</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>__DIR__/helper/helper.log</string>
  <key>StandardErrorPath</key><string>__DIR__/helper/helper.log</string>
</dict>
</plist>
